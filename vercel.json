{
  "version": 2,
  "builds": [
    { "src": "api/index.js", "use": "@vercel/node" },
    { "src": "index.html", "use": "@vercel/static" }
  ],
  "rewrites": [
    { "source": "/api/v1/tasks/:path*", "destination": "api/index.js" },
    { "source": "/api/v1/tasks", "destination": "api/index.js" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
